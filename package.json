{
  "name": "fedora-tv-os",
  "version": "3.3.0",
  "description": "Отдельная телевизионная Wayland-сессия для Fedora",
  "homepage": "https://github.com/BurnToShineact/fedora-tv-launcher",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BurnToShineact/fedora-tv-launcher.git"
  },
  "desktopName": "fedora-tv-os.desktop",
  "author": {
    "name": "BurnToShineact",
    "email": "BurnToShineact@users.noreply.github.com"
  },
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "pack:dir": "electron-builder --dir",
    "build:rpm": "electron-builder --linux rpm",
    "build:appimage": "electron-builder --linux AppImage",
    "release:github": "electron-builder --linux rpm --publish never",
    "release:metadata": "node scripts/update-release-metadata.js",
    "build:linux": "electron-builder --linux rpm",
    "check:js": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/launcher.js && node --check src/lib/system-utils.js && node --check scripts/update-release-metadata.js",
    "check:shell": "bash -n packaging/*.sh scripts/*.sh session/fedora-tv-os-home session/fedora-tv-os-logout session/fedora-tv-os-session session/fedora-tv-os-startup session/fedora-tv-os-system-settings",
    "check": "npm run check:js && npm run check:shell",
    "test": "node --test tests/*.test.js",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run check && npm test"
  },
  "dependencies": {
    "electron-updater": "^6.8.4"
  },
  "devDependencies": {
    "electron": "https://github.com/castlabs/electron-releases/archive/refs/tags/v43.0.0%2Bwvcus.tar.gz",
    "electron-builder": "^26.11.1"
  },
  "build": {
    "appId": "os.fedoratv.shell",
    "productName": "Fedora TV OS",
    "executableName": "fedora-tv-os",
    "files": [
      "src/**/*",
      "config/**/*",
      "assets/**/*",
      "package.json"
    ],
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "linux": {
      "target": [
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "System",
      "desktop": {
        "entry": {
          "Name": "Fedora TV OS (служебный компонент)",
          "Comment": "Домашний экран отдельной телевизионной сессии",
          "NoDisplay": "true"
        }
      },
      "syncDesktopName": true,
      "maintainer": "BurnToShineact <BurnToShineact@users.noreply.github.com>",
      "artifactName": "fedora-tv-os-${version}-${arch}.${ext}"
    },
    "rpm": {
      "packageName": "fedora-tv-os",
      "compression": "xz",
      "afterInstall": "packaging/after-install.sh",
      "afterRemove": "packaging/after-remove.sh",
      "depends": [
        "gtk3",
        "glib2",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "xdg-utils",
        "at-spi2-core",
        "flatpak",
        "gdm",
        "labwc",
        "polkit",
        "lxqt-policykit",
        "wlrctl",
        "wlr-randr",
        "wireplumber",
        "bluez",
        "libcec",
        "NetworkManager"
      ],
      "packageCategory": "System"
    },
    "extraResources": [
      {
        "from": "session",
        "to": "tv-session",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "packaging/fedora-tv-os-release.asc",
        "to": "release-key.asc"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "BurnToShineact",
        "repo": "fedora-tv-launcher",
        "releaseType": "release"
      }
    ]
  }
}
