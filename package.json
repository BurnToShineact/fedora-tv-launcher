{
  "name": "fedora-tv-os",
  "version": "2.2.2",
  "description": "Отдельная телевизионная Wayland-сессия для Fedora",
  "homepage": "https://github.com/BurnToShineact/fedora-tv-launcher",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BurnToShineact/fedora-tv-launcher.git"
  },
  "desktopName": "fedora-tv-os.desktop",
  "author": {
    "name": "BurnToShineact",
    "email": "BurnToShineact@users.noreply.github.com"
  },
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack:dir": "electron-builder --dir",
    "build:rpm": "electron-builder --linux rpm",
    "build:appimage": "electron-builder --linux AppImage",
    "release:github": "electron-builder --linux rpm --publish always",
    "build:linux": "electron-builder --linux rpm",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/launcher.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.4"
  },
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^26.11.1"
  },
  "build": {
    "appId": "os.fedoratv.shell",
    "productName": "Fedora TV OS",
    "executableName": "fedora-tv-os",
    "files": [
      "src/**/*",
      "config/**/*",
      "assets/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "System",
      "desktop": {
        "entry": {
          "Name": "Fedora TV OS (служебный компонент)",
          "Comment": "Домашний экран отдельной телевизионной сессии",
          "NoDisplay": "true"
        }
      },
      "syncDesktopName": true,
      "maintainer": "BurnToShineact <BurnToShineact@users.noreply.github.com>",
      "artifactName": "fedora-tv-os-${version}-${arch}.${ext}"
    },
    "rpm": {
      "packageName": "fedora-tv-os",
      "compression": "xz",
      "afterInstall": "packaging/after-install.sh",
      "afterRemove": "packaging/after-remove.sh",
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "xdg-utils",
        "at-spi2-core",
        "flatpak",
        "labwc",
        "polkit",
        "lxqt-policykit",
        "wlrctl"
      ],
      "packageCategory": "System"
    },
    "extraResources": [
      {
        "from": "session",
        "to": "tv-session",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "BurnToShineact",
        "repo": "fedora-tv-launcher",
        "releaseType": "release"
      }
    ]
  }
}
